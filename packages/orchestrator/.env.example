# AI Orchestrator Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# MySQL connection settings
AI_ORCH_DB_HOST=localhost
AI_ORCH_DB_PORT=3306
AI_ORCH_DB_USER=ai_orch
AI_ORCH_DB_PASS=super-secret
AI_ORCH_DB_NAME=ai_orch

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# HTTP server settings
AI_ORCH_HTTP_HOST=0.0.0.0
AI_ORCH_HTTP_PORT=8080
AI_ORCH_DEBUG=false

# CORS origins (comma-separated)
AI_ORCH_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# =============================================================================
# PATHS
# =============================================================================

# Repository root for artifact path validation
AI_ORCH_REPO_ROOT=/path/to/your/project

# Artifacts storage directory
AI_ORCH_ARTIFACTS_DIR=/path/to/.ai/artifacts

# =============================================================================
# OPTIONAL: DISCORD WEBHOOKS
# =============================================================================

# Set these in the dashboard Settings page, or here for initial setup
# DISCORD_ALERTS_WEBHOOK=https://discord.com/api/webhooks/xxx/yyy
# DISCORD_SUMMARY_WEBHOOK=https://discord.com/api/webhooks/xxx/zzz

# =============================================================================
# OPTIONAL: METRICS
# =============================================================================

# Prometheus metrics port (if using enterprise features)
# AI_ORCH_METRICS_PORT=9090
